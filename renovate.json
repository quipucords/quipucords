{
  "prHourlyLimit": 20,
  "packageRules": [
    {
      "description": "Tekton pipelines and tasks",
      "matchManagers": ["tekton"],
      "groupName": "tekton",
      "schedule": ["* 5-23 * * 5"]
    },
    {
      "description": "Containerfile base image updates",
      "matchManagers": ["dockerfile"],
      "groupName": "containerfile",
      "schedule": ["* 5-23 * * 5"]
    },
    {
      "description": "Language dependencies non-major updates",
      "matchManagers": ["npm", "pep621"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "language dependencies",
      "schedule": ["* 5-23 * * 1-5"]
    },
    {
      "description": "Language dependencies lockfile updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["lockFileMaintenance"],
      "groupName": "lockfiles update",
      "schedule": ["* 9-13 * * 1-5"]
    },
    {
      "description": "Disable major updates for language dependencies",
      "matchCategories": ["js", "python"],
      "matchUpdateTypes": ["major", "pin", "pinDigest", "digest", "rollback", "bump", "replacement"],
      "enabled": false
    },
    {
      "description": "Disable updates for Python - our dependency pipeline does not fit MintMaker model",
      "matchCategories": ["python"],
      "enabled": false
    }
  ]
}
